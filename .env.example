# Kopie dieser Datei als ".env.local" (Entwicklung) bzw. ".env" (Server) anlegen
# und die echten Werte eintragen. NIEMALS die echte .env committen!

# MySQL-Datenbank des Minecraft-Netzwerks
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=trycity_web
DB_PASSWORD=

# Geheimnis zum Signieren der Login-Sessions (JWT).
# Erzeugen mit:  openssl rand -base64 48
AUTH_SECRET=
